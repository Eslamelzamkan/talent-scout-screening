DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@127.0.0.1:5433/<db_name>
FINETUNED_MODEL_DIR=C:\path\to\resume_matcher_model
GROQ_API_KEY=<groq-api-key>
ALLOWED_ORIGINS=http://localhost:8501
JWT_SECRET_KEY=<replace-with-long-random-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=60
BCRYPT_ROUNDS=12
RUN_RATE_LIMIT=10/minute
MAX_REQUEST_BODY_BYTES=2000000
MAX_JOB_DESCRIPTION_CHARS=20000
MAX_RESUME_TEXT_CHARS=120000
MAX_RESUMES_PER_REQUEST=200
SKILL_ALIASES_PATH=config/skills_aliases.yml
